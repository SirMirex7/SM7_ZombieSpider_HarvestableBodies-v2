<config>
     <insertAfter xpath="/entity_classes/color[last()]">
         <color name="saltygold" value=".98,.867,.29, .55"/>
         <color name="saltyred" value=".925,.259,.094, .55"/>
     </insertAfter>
    
     <!-- ================================================== -->
     <!-- VANILLA CHANGES -->
     <!-- Notes: Making zombies harvestable and stay in the world longer after death-->
     <!--        Made it so Players hit the body instead of dropping a carcass / dead body block -->
     <!-- ================================================== -->    
     <insertAfter xpath="/entity_classes/entity_class/property[@name='Tags' and contains(@value, 'zombie')]/..//property[last()]">       
         <property name="DeadBodyHitPoints" value="350"/>
         <drop event="Harvest" name="foodRawMeat" count="0" tool_category="Butcher"/>
         <drop event="Harvest" name="foodRottingFlesh" tag="butcherHarvest" count="0,3"/>
         <drop event="Harvest" name="resourcePotassiumNitratePowder" tag="butcherHarvest" count="2,10"/>
	     <drop event="Harvest" name="resourceBone" tag="butcherHarvest" count="9"/>
	     <drop event="Harvest" name="resourceBone" tag="allToolsHarvest" count="3"/>
     </insertAfter>

