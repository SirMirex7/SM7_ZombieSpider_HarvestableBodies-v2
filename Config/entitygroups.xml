     -->
     
     <!-- [contains(@name ... also works...  -->
     <append xpath="/entitygroups/entitygroup[number(substring-after(/entitygroups/entitygroup[starts-with(@name, 'sleeperHordeStage')]/@name, 'GS')) &gt; 1 and number(substring-after(/entitygroups/entitygroup[starts-with(@name, 'sleeperHordeStage')]/@name, 'GS')) &lt; 200]">
