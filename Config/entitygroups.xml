     <!-- ADDING NEW ENTITYGROUPS for the new Spider Walkers -->
     <!-- Notes: zombieSpiderWalkerAll,     zombieSpiderWalker00,   zombieSpiderWalker01,   zombieSpiderWalker02,   zombieSpiderWalker03,   zombieSpiderWalker04 -->
     <!--                                   0 Normal,               1 Feral,                2 Radiated,             3 Charged,              4 Infernal -->
