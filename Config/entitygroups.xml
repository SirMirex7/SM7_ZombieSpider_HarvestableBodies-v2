         <e n="zombieSpiderWalker1" />         
     </append> 
     <append xpath="/entitygroups/entitygroup[number(substring-after(/entitygroups/entitygroup[starts-with(@name, 'sleeperHordeStage')]/@name, 'GS')) &gt; 200 and number(substring-after(/entitygroups/entitygroup[starts-with(@name, 'sleeperHordeStage')]/@name, 'GS')) &lt; 500]">
