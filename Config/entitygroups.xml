     <!-- ================================================== --> 
     <append xpath="/entitygroups">
         <entitygroup name="zombieSpiderWalkerAll">
             <e n="zombieSpiderWalker0" /> <!-- Normal -->
             <e n="zombieSpiderWalker1" /> <!-- Feral -->
             <e n="zombieSpiderWalker2" /> <!-- Radiated -->
             <e n="zombieSpiderWalker3" /> <!-- Charged -->
             <e n="zombieSpiderWalker4" /> <!-- Infernal -->
         </entitygroup>
     </append>
     <append xpath="/entitygroups">
         <entitygroup name="zombieSpiderWalker00">
             <e n="zombieSpiderWalker0" /> <!-- Normal -->
         </entitygroup>
     </append>
     <append xpath="/entitygroups">
         <entitygroup name="zombieSpiderWalker01">
             <e n="zombieSpiderWalker1" /> <!-- Feral -->
         </entitygroup>
     </append>
